class {
  onInput(input) {
    let activeIndex = 0;

    if (input.tabs) {
      input.tabs.forEach((tab, i) => {
        if (tab.active) {
          activeIndex = i;
        }
      });
    }

    this.state = { activeIndex };
  }

  setActiveIndex(newActiveIndex) {
    this.state.activeIndex = newActiveIndex;
  }

  handleTabClick(tabIndex, event) {
    this.setActiveIndex(tabIndex);
    event.preventDefault();
  }
}

